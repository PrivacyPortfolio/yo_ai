{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yo-ai.ai/schemas/v1/a2a-response.json",
  "title": "A2AResponse_v1",
  "description": "A2A v1.0 response with standardized error handling and task metadata",
  "type": "object",
  "required": ["method", "metadata"],
  "properties": {
    "method": { "type": "string" },
    "result": { "type": "object" },
    "error": {
      "type": "object",
      "properties": {
        "code": { "type": "integer" },
        "message": { "type": "string" },
        "data": { "type": "object" }
      },
      "required": ["code", "message"]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "taskID": { "type": "string", "format": "uuid" },
        "status": { 
          "type": "string", 
          "enum": ["pending", "processing", "completed", "failed"] 
        }
      },
      "required": ["taskID"]
    }
  },
  "oneOf": [
    { "$ref": "https://example.com/schemas/v1/send-message-response.json" },
    { "$ref": "https://example.com/schemas/v1/get-task-response.json" }
    /* Additional response refs */
  ]
}
